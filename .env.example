HOST_PORT=8080
KAFKA_BOOTSTRAP_SERVERS=your-broker:9092
KAFKA_CONSUMER_GROUP_ID=log-dashboard
KAFKA_MAX_POLL_RECORDS=500
LOGSTREAM_TOPICS=server-topic,system-topic,app1-topic,app2-topic,app3-topic,app4-topic
LOGSTREAM_ALLOWED_ORIGINS=https://myapp.com
JVM_MAX_HEAP=512m

# Directory where log files are stored on the host (must match paths in SPRING_APPLICATION_JSON)
LOG_DIR=/var/log/logstream

# Topic to log file mappings — add/remove topics here without touching any yaml files
SPRING_APPLICATION_JSON={"logstream":{"log-files":{"server-topic":"/var/log/logstream/server.log","system-topic":"/var/log/logstream/system.log","app1-topic":"/var/log/logstream/app1.log","app2-topic":"/var/log/logstream/app2.log","app3-topic":"/var/log/logstream/app3.log","app4-topic":"/var/log/logstream/app4.log"}}}
