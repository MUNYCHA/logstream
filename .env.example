HOST_PORT=8080
KAFKA_BOOTSTRAP_SERVERS=your-broker:9092
KAFKA_CONSUMER_GROUP_ID=log-dashboard
KAFKA_MAX_POLL_RECORDS=500
LOGSTREAM_TOPICS=server-topic,system-topic,app1-topic,app2-topic,app3-topic,app4-topic
# CRITICAL: must EXACTLY match the public origin the browser loads the UI from
# (scheme + host + non-default port, NO trailing slash). This value gates BOTH
# REST CORS and the WebSocket handshake (WebSocketConfig.setAllowedOrigins) — a
# mismatch makes every WS connection fail with 403 and no upgrade.
# Bare IP over HTTP on port 80:   http://10.0.0.5
# Bare IP on a custom host port:  http://10.0.0.5:8080
# Behind TLS:                     https://logs.example.com
# Comma-separate to allow several origins.
LOGSTREAM_ALLOWED_ORIGINS=http://10.0.0.5
JVM_MAX_HEAP=512m

# Directory where log files live on the host — files must be named {topic}.log
# e.g. server-topic → /var/log/logstream/server-topic.log
LOGSTREAM_LOG_DIR=/var/log/logstream

# SSO — JWKS endpoint for JWT validation.
# Use the INTERNAL Docker hostname (keycloak), NOT the public IP: the API fetches
# signing keys server-to-server inside the `monitoring` network. The token's
# issuer is the public URL, but with only jwk-set-uri configured Spring validates
# signature + expiry (not issuer), so the internal/public split is fine.
SSO_JWKS_URI=http://keycloak:8080/auth/realms/logstream/protocol/openid-connect/certs
